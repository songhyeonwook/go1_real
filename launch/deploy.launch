<launch>
    <!-- Model Configuration -->
    <arg name="model_path" default="$(find go1_real)/model/policy_numpy.npz" />
    <arg name="injured_leg_idx" default="-1" /> <!-- -1: Normal, 0: FL, 1: FR, 2: RL, 3: RR -->
    
    <!-- Control Gains -->
    <arg name="Kp" default="30.0" />
    <arg name="Kd" default="1.5" />
    <arg name="enable_policy" default="false" />
    <arg name="stand_up_time" default="10.0" />
    <arg name="action_scale_multiplier" default="0.2" />
    <arg name="policy_ramp_time" default="8.0" />
    <arg name="shutdown_damp_repeats" default="20" />
    <arg name="shutdown_damp_dt" default="0.02" />

    <!-- Main Deployment Node -->
    <node name="go1_policy_deploy" pkg="go1_real" type="deploy_policy.py" output="screen">
        <param name="model_path" value="$(arg model_path)" />
        <param name="injured_leg_idx" value="$(arg injured_leg_idx)" />
        <param name="Kp" value="$(arg Kp)" />
        <param name="Kd" value="$(arg Kd)" />
        <param name="enable_policy" value="$(arg enable_policy)" />
        <param name="stand_up_time" value="$(arg stand_up_time)" />
        <param name="action_scale_multiplier" value="$(arg action_scale_multiplier)" />
        <param name="policy_ramp_time" value="$(arg policy_ramp_time)" />
        <param name="shutdown_damp_repeats" value="$(arg shutdown_damp_repeats)" />
        <param name="shutdown_damp_dt" value="$(arg shutdown_damp_dt)" />
    </node>
</launch>
