+        # 체공 시간 보상과 흔들림 페널티의 밸런스를 바로잡습니다.
+
+        use_phase2_gait_tuning = os.getenv("GO1_PHASE2_GAIT_TUNING", "1").strip().lower() in {
+            "1",
+            "true",
+            "yes",
+            "on",
+        }
+
+        if use_phase2_gait_tuning and hasattr(self.rewards, "feet_air_time"):
