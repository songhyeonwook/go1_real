+            # -> Pacing이나 토끼뜀을 방지하고 Trot으로 수렴하게 만듦 (기존 -0.05 -> -0.1)
+            self.rewards.ang_vel_xy_l2.weight = float(os.getenv("GO1_ANG_VEL_XY_L2_WEIGHT", "-0.1"))
