+                    "ramp_start_steps": int(os.getenv("GO1_FRONT_REAR_LOAD_DIST_RAMP_START_STEPS", "2000")),
+                    "ramp_duration_steps": int(os.getenv("GO1_FRONT_REAR_LOAD_DIST_RAMP_STEPS", "6000")),
