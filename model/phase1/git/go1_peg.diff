+                    "ramp_duration_steps": int(os.getenv("GO1_CONTACT_FORCE_ASYM_RAMP_STEPS", "6000")),
+                },
+            )
+            self.rewards.duty_factor_asymmetry = RewTerm(
+                func=mdp.penalize_duty_factor_asymmetry,
