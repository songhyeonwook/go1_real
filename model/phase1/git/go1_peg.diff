+                params={"velocity_range": {"x": (-0.5, 0.5), "y": (-0.5, 0.5)}},
+            )
+
+            # (d) Gaussian observation noise: joint states N(0,0.02), IMU N(0,0.05)
+            _pol = self.observations.policy
