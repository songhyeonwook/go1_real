+def sanitize_rsl_rl_experiment_name(experiment_name: str | None) -> str:
+    """Strip leading path separators.
+
+    On POSIX, ``os.path.join("logs", "rsl_rl", "/foo")`` becomes ``/foo``, dropping
+    the intended ``logs/rsl_rl`` prefix when *experiment_name* was given as ``/foo``.
+    """
+    return (experiment_name or "").strip().strip("/\\")
+
+
+def rsl_rl_experiment_log_dir(experiment_name: str | None, *, root: str | None = None) -> str:
+    """Absolute path to ``<root>/logs/rsl_rl/<experiment_name>`` (default *root* is cwd)."""
+    sub = sanitize_rsl_rl_experiment_name(experiment_name)
+    base = os.getcwd() if root is None else root
+    return os.path.abspath(os.path.join(base, "logs", "rsl_rl", sub))
+
